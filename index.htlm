<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Asha &amp; Tejavati | Wedding Invitation</title>
    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts - Luxury Script + Elegant -->
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&amp;family=Playfair+Display:wght@400;700&amp;family=Poppins:wght@300;400;500&amp;display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Great+Vibes&amp;family=Playfair+Display:wght@400;700&amp;family=Poppins:wght@300;400;500&amp;display=swap');

        :root {
            --pink: #f9c3d8;
            --gold: #d4af77;
            --cream: #fff8f0;
            --red: #b91c1c;
        }

        .tail-container {
            font-family: 'Poppins', system-ui, sans-serif;
        }
        
        .script-font {
            font-family: 'Great Vibes', cursive;
        }
        
        .heading-font {
            font-family: 'Playfair Display', serif;
        }

        /* Background gradient */
        .hero-bg {
            background: linear-gradient(135deg, #fff8f0 0%, #f9e8e0 100%);
        }

        /* Falling petals */
        .petal {
            position: absolute;
            font-size: 2rem;
            opacity: 0.85;
            animation: fall linear forwards;
            z-index: 1;
            pointer-events: none;
            text-shadow: 0 0 10px rgba(212, 175, 119, 0.4);
        }

        @keyframes fall {
            to {
                transform: translateY(120vh) rotate(720deg);
            }
        }

        /* Luxury frame for couple photo */
        .photo-frame {
            position: relative;
            border: 12px solid #d4af77;
            border-image: linear-gradient(#d4af77, #b91c1c, #d4af77) 1;
            box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.4),
                        inset 0 0 40px rgba(212, 175, 119, 0.3);
        }

        /* Countdown */
        .countdown-digit {
            font-family: 'Playfair Display', serif;
            background: rgba(255,255,255,0.95);
            box-shadow: 0 10px 15px -3px rgb(212 175 119 / 0.3);
        }

        /* Glowing button */
        .glow-btn {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 0 30px -5px rgb(212 175 119),
                        0 0 60px -10px rgb(185 28 28);
        }
        .glow-btn:hover {
            transform: scale(1.08) translateY(-4px);
            box-shadow: 0 0 50px -5px rgb(212 175 119),
                        0 0 80px -10px rgb(185 28 28);
        }

        /* Page transition */
        .page {
            transition: opacity 1.2s cubic-bezier(0.23, 1, 0.32, 1),
                        transform 1.2s cubic-bezier(0.23, 1, 0.32, 1);
        }
        
        /* Timeline line */
        .timeline-line {
            position: absolute;
            left: 50%;
            top: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(to bottom, transparent, #d4af77, transparent);
        }
        
        /* Gallery hover */
        .gallery-img {
            transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .gallery-img:hover {
            transform: scale(1.08) rotate(2deg);
            box-shadow: 0 25px 50px -12px rgb(185 28 28 / 0.4);
        }

        /* Lightbox */
        #lightbox {
            animation: lightboxPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        @keyframes lightboxPop {
            0% { transform: scale(0.6); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        /* Scroll reveal */
        .reveal {
            opacity: 0;
            transform: translateY(60px);
            transition: all 1s cubic-bezier(0.23, 1, 0.32, 1);
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* Music toggle */
        .music-btn {
            animation: pulse 2s infinite;
        }
    </style>
</head>
<body class="tail-container bg-[#fff8f0] text-[#3f2e1e] overflow-x-hidden">

    <!-- PAGE 1: CINEMATIC WELCOME -->
    <div id="page1" class="page min-h-screen flex items-center justify-center relative hero-bg overflow-hidden">
        
        <!-- Floating petals container -->
        <div id="petals1" class="absolute inset-0 pointer-events-none z-10"></div>

        <!-- Subtle mandala background pattern -->
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,#d4af7715_0%,transparent_70%)] z-0"></div>

        <div class="max-w-4xl mx-auto text-center relative z-20 px-6 py-12">
            <!-- Decorative top element -->
            <div class="flex justify-center mb-8">
                <div class="flex items-center gap-3 text-[#d4af77]">
                    <div class="h-px w-16 bg-gradient-to-r from-transparent to-[#d4af77]"></div>
                    <i class="fa-solid fa-kalash text-3xl"></i>
                    <div class="h-px w-16 bg-gradient-to-l from-transparent to-[#d4af77]"></div>
                </div>
            </div>

            <!-- Couple Photo -->
            <div class="photo-frame mx-auto max-w-md rounded-3xl overflow-hidden mb-10 shadow-2xl">
                <img id="hero-couple" src="https://picsum.photos/id/1015/800/900" 
                     alt="Asha &amp; Tejavati" 
                     class="w-full h-auto object-cover">
            </div>

            <!-- Names -->
            <div class="mb-6">
                <h1 class="script-font text-[6.5rem] leading-none text-[#b91c1c] tracking-[-4px]">
                    Asha
                </h1>
                <div class="flex items-center justify-center gap-4 my-1">
                    <div class="h-px w-16 bg-[#d4af77]"></div>
                    <i class="fa-solid fa-heart text-4xl text-[#d4af77] animate-pulse"></i>
                    <div class="h-px w-16 bg-[#d4af77]"></div>
                </div>
                <h1 class="script-font text-[6.5rem] leading-none text-[#b91c1c] tracking-[-4px]">
                    Tejavati
                </h1>
            </div>

            <!-- Subtitle -->
            <p class="text-xl font-light tracking-widest text-[#5c4033] mb-8 max-w-md mx-auto">
                Together with their families, they invite you to celebrate their wedding
            </p>

            <!-- Date -->
            <div class="mb-8">
                <div class="inline-flex items-center gap-2 bg-white/80 backdrop-blur-md px-8 py-3 rounded-2xl border border-[#d4af77]/30">
                    <i class="fa-solid fa-calendar-day text-[#b91c1c]"></i>
                    <span class="heading-font text-2xl font-medium text-[#3f2e1e]">26 February 2026</span>
                </div>
            </div>

            <!-- Animated Countdown -->
            <div id="countdown" class="grid grid-cols-4 gap-4 max-w-xs mx-auto mb-12">
                <!-- JS populated -->
            </div>

            <!-- Open Invitation Button -->
            <button onclick="openInvitation()" 
                    class="glow-btn group relative px-14 py-6 bg-gradient-to-r from-[#b91c1c] to-[#d4af77] text-white text-xl font-medium rounded-3xl flex items-center gap-3 mx-auto hover:from-[#d4af77] hover:to-[#b91c1c]">
                <span class="script-font text-3xl">Open Invitation</span>
                <i class="fa-solid fa-arrow-right text-2xl group-active:rotate-45 transition"></i>
            </button>

            <!-- Decorative bells -->
            <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex gap-8 text-[#d4af77] opacity-30">
                <i class="fa-solid fa-bell text-3xl"></i>
                <i class="fa-solid fa-bell text-3xl"></i>
            </div>
        </div>

        <!-- Music toggle (floating) -->
        <button onclick="toggleMusic()" 
                class="music-btn fixed bottom-8 right-8 z-50 bg-white shadow-xl w-14 h-14 rounded-2xl flex items-center justify-center text-3xl border-4 border-[#d4af77]">
            <i id="music-icon" class="fa-solid fa-music"></i>
        </button>

        <!-- Footer hint -->
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-[#d4af77]/60 text-xs tracking-widest font-light">
            SCROLL OR TAP TO BEGIN • 2026
        </div>
    </div>

    <!-- PAGE 2: WEDDING DETAILS -->
    <div id="page2" class="page hidden min-h-screen bg-[#fff8f0]">
        
        <!-- Floating petals container for page 2 -->
        <div id="petals2" class="fixed inset-0 pointer-events-none z-[-1]"></div>

        <!-- Navbar -->
        <nav class="fixed top-0 left-0 right-0 bg-white/90 backdrop-blur-lg border-b border-[#d4af77]/20 z-50">
            <div class="max-w-7xl mx-auto px-6 py-5 flex justify-between items-center">
                <div onclick="goBackToPage1()" class="flex items-center gap-2 cursor-pointer">
                    <i class="fa-solid fa-arrow-left text-[#d4af77]"></i>
                    <span class="script-font text-2xl text-[#b91c1c]">Asha &amp; Tejavati</span>
                </div>
                <div class="flex items-center gap-6 text-sm">
                    <a href="#bride-groom" class="hover:text-[#b91c1c] transition">Couple</a>
                    <a href="#timeline" class="hover:text-[#b91c1c] transition">Events</a>
                    <a href="#gallery" class="hover:text-[#b91c1c] transition">Gallery</a>
                    <a href="#venue" class="hover:text-[#b91c1c] transition">Venue</a>
                    <button onclick="toggleMusic()" 
                            class="px-5 py-2 rounded-2xl bg-[#d4af77]/10 hover:bg-[#d4af77]/20 text-xs font-medium flex items-center gap-2">
                        <i class="fa-solid fa-music"></i>
                        <span id="music-text">PLAY MUSIC</span>
                    </button>
                </div>
            </div>
        </nav>

        <div class="pt-24 pb-20 max-w-5xl mx-auto px-6 space-y-24">

            <!-- SECTION 1: BRIDE &amp; GROOM -->
            <section id="bride-groom" class="reveal">
                <div class="text-center mb-12">
                    <div class="inline-flex items-center gap-3 text-[#d4af77]">
                        <div class="h-px w-12 bg-[#d4af77]"></div>
                        <i class="fa-solid fa-ring text-2xl"></i>
                        <div class="h-px w-12 bg-[#d4af77]"></div>
                    </div>
                    <h2 class="heading-font text-5xl text-[#b91c1c] mt-3">Asha &amp; Tejavati</h2>
                </div>
                
                <div class="grid md:grid-cols-2 gap-12">
                    <!-- Bride -->
                    <div class="text-center group">
                        <div class="relative mx-auto max-w-xs overflow-hidden rounded-3xl photo-frame">
                            <img src="https://picsum.photos/id/1009/600/800" 
                                 alt="Asha" 
                                 class="w-full h-auto transition-all group-hover:scale-110">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end justify-center pb-8">
                                <div class="text-white">
                                    <div class="script-font text-5xl">Asha</div>
                                    <div class="text-xs tracking-widest text-[#d4af77]">THE BRIDE</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Groom -->
                    <div class="text-center group">
                        <div class="relative mx-auto max-w-xs overflow-hidden rounded-3xl photo-frame">
                            <img src="https://picsum.photos/id/1012/600/800" 
                                 alt="Tejavati" 
                                 class="w-full h-auto transition-all group-hover:scale-110">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end justify-center pb-8">
                                <div class="text-white">
                                    <div class="script-font text-5xl">Tejavati</div>
                                    <div class="text-xs tracking-widest text-[#d4af77]">THE GROOM</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- SECTION 2: TIMELINE -->
            <section id="timeline" class="reveal">
                <div class="text-center mb-12">
                    <h2 class="heading-font text-5xl text-[#b91c1c]">Our Wedding Journey</h2>
                    <p class="text-[#5c4033] mt-3">Five beautiful days of celebrations</p>
                </div>
                
                <div class="relative max-w-2xl mx-auto">
                    <!-- Vertical line -->
                    <div class="timeline-line hidden md:block"></div>
                    
                    <div class="space-y-16 relative">
                        <!-- Event 1 -->
                        <div class="flex flex-col md:flex-row gap-8 items-start">
                            <div class="w-12 h-12 bg-white rounded-2xl shadow flex items-center justify-center text-3xl flex-shrink-0 z-10">🌸</div>
                            <div class="flex-1 bg-white rounded-3xl p-8 shadow">
                                <div class="text-[#d4af77] text-sm font-medium tracking-widest">23 FEB 2026</div>
                                <div class="heading-font text-3xl text-[#3f2e1e]">Mandap Muhurat</div>
                                <p class="mt-2 text-[#5c4033]">Blessing of the sacred mandap with family elders</p>
                            </div>
                        </div>
                        
                        <!-- Event 2 -->
                        <div class="flex flex-col md:flex-row gap-8 items-start">
                            <div class="w-12 h-12 bg-white rounded-2xl shadow flex items-center justify-center text-3xl flex-shrink-0 z-10">🥁</div>
                            <div class="flex-1 bg-white rounded-3xl p-8 shadow">
                                <div class="text-[#d4af77] text-sm font-medium tracking-widest">24 FEB 2026</div>
                                <div class="heading-font text-3xl text-[#3f2e1e]">Matka Pujan</div>
                                <p class="mt-2 text-[#5c4033]">Traditional worship of the matka before festivities begin</p>
                            </div>
                        </div>
                        
                        <!-- Event 3 -->
                        <div class="flex flex-col md:flex-row gap-8 items-start">
                            <div class="w-12 h-12 bg-white rounded-2xl shadow flex items-center justify-center text-3xl flex-shrink-0 z-10">🐎</div>
                            <div class="flex-1 bg-white rounded-3xl p-8 shadow">
                                <div class="text-[#d4af77] text-sm font-medium tracking-widest">25 FEB 2026</div>
                                <div class="heading-font text-3xl text-[#3f2e1e]">Baraat</div>
                                <p class="mt-2 text-[#5c4033]">The grand procession with music, dance &amp; dhol</p>
                            </div>
                        </div>
                        
                        <!-- Event 4 -->
                        <div class="flex flex-col md:flex-row gap-8 items-start">
                            <div class="w-12 h-12 bg-white rounded-2xl shadow flex items-center justify-center text-3xl flex-shrink-0 z-10">💍</div>
                            <div class="flex-1 bg-white rounded-3xl p-8 shadow">
                                <div class="text-[#d4af77] text-sm font-medium tracking-widest">26 FEB 2026 • 4:00 PM</div>
                                <div class="heading-font text-3xl text-[#3f2e1e]">Vivah Ceremony</div>
                                <p class="mt-2 text-[#5c4033]">The sacred union under the mandap with pheras &amp; vows</p>
                            </div>
                        </div>
                        
                        <!-- Event 5 -->
                        <div class="flex flex-col md:flex-row gap-8 items-start">
                            <div class="w-12 h-12 bg-white rounded-2xl shadow flex items-center justify-center text-3xl flex-shrink-0 z-10">🎉</div>
                            <div class="flex-1 bg-white rounded-3xl p-8 shadow">
                                <div class="text-[#d4af77] text-sm font-medium tracking-widest">26 FEB 2026 • 9:00 PM</div>
                                <div class="heading-font text-3xl text-[#3f2e1e]">Baraat Return &amp; Reception</div>
                                <p class="mt-2 text-[#5c4033]">Celebration, dinner &amp; dancing under the stars</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- SECTION 3: PHOTO GALLERY -->
            <section id="gallery" class="reveal">
                <div class="text-center mb-12">
                    <h2 class="heading-font text-5xl text-[#b91c1c]">Moments to Remember</h2>
                </div>
                
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6" id="gallery-grid">
                    <!-- Populated by JS -->
                </div>
            </section>

            <!-- SECTION 4: VENUE -->
            <section id="venue" class="reveal bg-white rounded-3xl shadow-xl overflow-hidden">
                <div class="grid md:grid-cols-2">
                    <!-- Info -->
                    <div class="p-12">
                        <div class="flex items-center gap-3 mb-6">
                            <i class="fa-solid fa-location-dot text-4xl text-[#d4af77]"></i>
                            <div>
                                <div class="text-[#b91c1c] text-sm font-medium">THE VENUE</div>
                                <div class="heading-font text-4xl">Taj Lake Palace</div>
                                <div class="text-[#5c4033]">Udaipur, Rajasthan</div>
                            </div>
                        </div>
                        
                        <p class="text-[#3f2e1e] leading-relaxed mb-8">
                            Nestled on the serene waters of Lake Pichola, this majestic palace offers the perfect royal setting for our union.
                        </p>
                        
                        <div class="space-y-6 text-sm">
                            <div class="flex gap-4">
                                <i class="fa-solid fa-clock mt-1 text-[#d4af77]"></i>
                                <div>
                                    <div class="font-medium">26 February 2026</div>
                                    <div class="text-[#5c4033]">4:00 PM onwards</div>
                                </div>
                            </div>
                            <div class="flex gap-4">
                                <i class="fa-solid fa-map-marker-alt mt-1 text-[#d4af77]"></i>
                                <div>
                                    Lake Pichola,<br>
                                    Udaipur, Rajasthan 313001
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-12 flex flex-wrap gap-4">
                            <a href="https://maps.google.com
